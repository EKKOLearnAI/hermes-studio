{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aurora OS",
  "version": "0.1.0",
  "identifier": "com.hermes.auroraos",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:8648",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Aurora OS",
        "width": 1280,
        "height": 800,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
