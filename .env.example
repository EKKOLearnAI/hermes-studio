# Hermes Web UI Configuration
# Copy this file to .env and modify as needed

# Docker image settings
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
WEBUI_IMAGE=hermes-web-ui-local:latest
WEBUI_CONTAINER_NAME=hermes-webui

# Data directory (host path)
HERMES_DATA_DIR=./hermes_data

# Web UI settings
PORT=6060
AUTH_DISABLED=false

# Gateway settings (optional)
# GATEWAY_DEFAULT_HOST=127.0.0.1

# Notes:
# - Container runs as root for simplicity
# - HERMES_BIN is set to /opt/hermes/.venv/bin/hermes
# - HERMES_HOME is set to /home/agent/.hermes
# - Ports 8642-8670 are exposed for multi-profile gateway support
# - Workspace is mounted at /home/agent/workspace
# - Volumes use :z suffix for SELinux compatibility (Podman)
