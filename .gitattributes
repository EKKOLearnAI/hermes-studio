* text=auto

# Linux-sensitive runtime files must always use LF.
*.sh text eol=lf
*.service text eol=lf
*.env text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Source and docs also stay on LF to avoid cross-platform drift.
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf

# Windows scripts keep CRLF when needed.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
